import "fmt";

Vector2 :: struct {
    x, y: f32;
}

Fruit :: enum {
    mango,
    kiwi,
    dragonfruit,
    apple,
    orange,
    grape,
}

main :: () {
    {
        // Simple numbers
        numbers: [..]u8;
        
        append(numbers, 1 + 2);
        append(numbers, 2);
        append(numbers, 3);
        append(numbers, 4);
        append(numbers, 5);
    
        for v in numbers {
            print("v = %\n", v);
        }
    
        assert(numbers.count == 5);
        assert(numbers.capacity == 8);
    }
    {
        // Structs
        verticies: [..]Vector2;

        append(verticies, {1, 2});
        append(verticies, {3, 4});
        append(verticies, {5, 6});
        append(verticies, {7, 8});
        append(verticies, {9, 10});

        for v in verticies {
            print("v = %\n", v);
        }
    }
    {
        // Struct, but in a variable
        arr: [..]Vector2;

        start := Vector2{6, 9};
        append(arr, start);

        for v in arr {
            Print("%", v);
        }
    }
    {
        // Enums
        fruits: [..]Fruit;

        append(fruits, .mango);
        append(fruits, .kiwi);
        append(fruits, .dragonfruit);
        append(fruits, .apple);
        append(fruits, .orange);

        for v in fruits {
            print("v = %\n", v);
        }
    }
    

}