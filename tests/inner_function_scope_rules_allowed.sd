import "fmt";

main :: () {
    {
        // Constants can be seen in inner functions
        Color :: struct {
            r, g, b, a: u8;
        }

        Red :: Color{r = 255};

        a :: () {
            Print("%", Red); // -> Color{ r = 255, g = 0, b = 0, a = 0 }
        };

        a();
    }

    {
        // Inner inner functions can be called
        foo :: () {
            Print("foo");
        };

        bar :: () {
            foo();
        }

        bar(); // -> foo
    }
}