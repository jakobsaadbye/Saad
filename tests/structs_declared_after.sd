import "fmt";

Movie :: struct {
    title: string;
    rating: Rating;
}

Rating :: struct {
    oneStars: int;
    fiveStars: int;
};

main :: () {
    movie := Movie{
        title = "Hungergames 3 - Mockingbird",
        rating = {
            oneStars = 10,
            fiveStars = 50,
        }
    };

    Print("%", movie);
}