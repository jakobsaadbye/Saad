import "c_stdlib";
import "c_string";
import "arrays";

////////////////////////////////////////////////////////////////////////////////////
//   StringBuilder
////////////////////////////////////////////////////////////////////////////////////
StringBuilder :: struct {
    buffer:    *u8;
    cursor:    int;
    capacity:  int;
}

NewStringBuilder :: (initialCapacity: int) -> StringBuilder {
    buffer: *u8 = malloc(initialCapacity);

    memset(buffer, 0, initialCapacity);

    return {
        buffer   = buffer,
        cursor   = 0,
        capacity = initialCapacity,
    };
}

internalGrow :: method (sb: *StringBuilder, len: int) {
    newCapacity := sb.capacity * 2;
    while newCapacity <= sb.cursor + len {
        newCapacity *= 2;
    }

    newBuffer: *u8 = realloc(sb.buffer, newCapacity);
    if newBuffer == null {
        print("OutOfMemoryException: Failed to reallocate a new buffer for the string builder");
        exit(1);
    }

    sb.buffer = newBuffer;
    sb.capacity = newCapacity;

    memset(&sb.buffer[sb.cursor], 0, newCapacity - sb.cursor);
}

internalAdd :: method (sb: *StringBuilder, strPtr: *u8, len: int) {
    if sb.cursor + len < sb.capacity {
        memcpy(&sb.buffer[sb.cursor], strPtr, len);
        sb.cursor += len;
    } else {
        sb.internalGrow(len);
    
        // Append the string
        memcpy(&sb.buffer[sb.cursor], strPtr, len);
        sb.cursor += len;
    }
}

addStringSlice :: method (sb: *StringBuilder, str: string, start: int, end: int) {
    strLen := end - start;
    strPtr := str.data;
    strPtr = &strPtr[start];
    sb.internalAdd(strPtr, strLen);
}

addChar :: method (sb: *StringBuilder, c: u8) {
    strLen := 1;
    strPtr := &c;
    sb.internalAdd(strPtr, strLen);
}

addString :: method (sb: *StringBuilder, str: string) {
    sb.internalAdd(str.data, str.len);
}

addFloat32 :: method (sb: *StringBuilder, v: f32) {
    buf: [18]u8;
    sprintf(buf.data, xx "%f", v);

    str: string;
    str.data = buf.data as *u8;
    str.len = strlen(buf.data);
    sb.internalAdd(str.data, str.len);
}

addFloat64 :: method (sb: *StringBuilder, v: f64) {
    buf: [18]u8;
    sprintf(buf.data, xx "%lf", v);

    str: string;
    str.data = buf.data as *u8;
    str.len = strlen(buf.data);
    sb.internalAdd(str.data, str.len);
}

addInt64 :: method (sb: *StringBuilder, v: s64) {
    if v == 0 {
        sb.addChar(48); // 0
        return;
    }

    if v < 0 {
        sb.addChar(45); // -
        v = -v;
    }

    tmp: [32]u8; // enough for 64-bit int

    n := 0;
    while v != 0 {
        digit := v % 10;
        v = v / 10;

        c := (digit + 48) as u8;

        tmp[n] = c;
        n += 1;
    }

    // Add the digits in reverse order
    for i in 0..n {
        ri := (n - 1) - i;
        c := tmp[ri];
        sb.addChar(c);
    }
}

addUInt64 :: method (sb: *StringBuilder, v: u64) {
    if v == 0 {
        sb.addChar(48); // 0
        return;
    }

    tmp: [32]u8; // enough for 64-bit int

    n := 0;
    while v != 0 {
        digit := v % 10;
        v = v / 10;

        c := (digit + 48) as u8;

        tmp[n] = c;
        n += 1;
    }

    // Add the digits in reverse order
    for i in 0..n {
        ri := (n - 1) - i;
        c := tmp[ri];
        sb.addChar(c);
    }
}

addAnyValue :: method (sb: *StringBuilder, arg: any)  {
    if arg.type.kind == .Int {
        prim := arg.type as *TypePrimitive;

        if prim.kind == .U8 {
            value := *(arg.data as *u8);
            sb.addUInt64(value as u64);
        } 
        else if prim.kind == .U16 {
            value := *(arg.data as *u16);
            sb.addUInt64(value as u64);
        }
        else if prim.kind == .U32 || prim.kind == .Uint {
            value := *(arg.data as *u32);
            sb.addUInt64(value as u64);
        }
        else if prim.kind == .U64 {
            value := *(arg.data as *u64);
            sb.addUInt64(value);
        }
        else if prim.kind == .S8 {
            value := *(arg.data as *s8);
            sb.addInt64(value as s64);
        }
        else if prim.kind == .S16 {
            value := *(arg.data as *s16);
            sb.addInt64(value as s64);
        }
        else if prim.kind == .S32 || prim.kind == .Int {
            value := *(arg.data as *s32);
            sb.addInt64(value as s64);
        }
        else if prim.kind == .S64 {
            value := *(arg.data as *s64);
            sb.addInt64(value);
        } else {
            // Unhandled
            sb.addString("UNHANDLED");
        }
    }
    else if arg.type.kind == .Float {
        if (arg.type.size == 4) {
            value := arg.data as *f32;
            sb.addFloat32(*value);
        } else {
            value := arg.data as *f64;
            sb.addFloat64(*value);
        }
    }
    else if arg.type.kind == .Bool {
        value := arg.data as *bool;
        if *value {
            sb.addString("true");
        } else {
            sb.addString("false");
        }
    }
    else if arg.type.kind == .String {
        value := arg.data as *string;
        // sb.addString("'");
        sb.addString(*value);
        // sb.addString("'");
    }
    else if arg.type.kind == .Enum {
        enumType := arg.type as *TypeEnum;
        sb.addString(".");
        sb.addString(enumType.valueName);
    }
    else if arg.type.kind == .Pointer {
        ptrType := arg.type as *TypePointer;
        value := arg.data as **void;

        buf: [64]u8;
        written := sprintf(buf.data, xx "0x%p", *value);

        str: string;
        str.data = buf.data;
        str.len  = written; // written;

        sb.addString(str);
    }
    else if arg.type.kind == .Array {
        arrType := arg.type as *TypeArray;
        data := arg.data as **void;

        if *data == null {
            sb.addString("[]");
            return;
        }

        sb.addString("[");
        for i in 0..arrType.count {
            
            elemSize := arrType.elemType.size;

            elemPtr: *u8 = null;
            if arrType.kind == .Fixed {
                arrPtr := arg.data as **u8;
                elem0Ptr := *arrPtr;
                elemPtr = &elem0Ptr[i * elemSize];
            } else if arrType.kind == .Slice {
                slicePtr := arg.data as *[]u8;
                slice := *slicePtr;
                elem0 := slice.data;
                elemPtr = &elem0[i * elemSize];
            } else if arrType.kind == .Dynamic {
                dynArrPtr := arg.data as *[..]u8;
                dynArr := *dynArrPtr;
                elem0 := dynArr.data;
                elemPtr = &elem0[i * elemSize];
            }

            // Only show the full value if its a primitive type since we don't
            // generate type descriptors for each element.
            if arrType.elemType.isPrimitive() || arrType.elemType.kind == .String {
                value: any;
                value.type = arrType.elemType;
                value.data = elemPtr;
                sb.addAnyValue(value);
            } 
            else {
                buf: [64]u8;
                sprintf(buf.data, xx "0x%p", elemPtr);
                str: string;
                str.data = buf.data;
                str.len  = strlen(buf.data);
                sb.addString(str);
            }

            if i != arrType.count - 1 {
                sb.addString(", ");
            }
        }
        sb.addString("]");
    }
    else if arg.type.kind == .Struct {
        structType := arg.type as *TypeStruct;
        sb.addString(structType.head.name);
        sb.addString("{ ");
        for member, i in structType.members {
            sb.addString(member.name);
            sb.addString(" = ");

            // print("%\n", member.name);
            
            value: any;
            value.type = member.type;
            value.data = member.value;
            sb.addAnyValue(value);

            if i != structType.members.count - 1 {
                sb.addString(", ");
            }

        }
        sb.addString(" }");



    }
    else {
        sb.addString("<");
        sb.addString(arg.type.name);
        sb.addString(">");
    }
}

add :: method (sb: *StringBuilder, format: string, args: ...any) {

    // Scan the format string to find all the placeholders
    placeholderIndicies: [..]int;
    for c, i in format {
        if c == 37 { // '%'
            appendInt(&placeholderIndicies, i);
        }
    }

    // Build up the result string by pasting each segment of the source string
    cursor := 0;
    for index, i in placeholderIndicies {

        // Add the static text up untill the placeholder
        sb.addStringSlice(format, cursor, index);

        // Fill in the placeholder
        arg := args[i];
        sb.addAnyValue(arg);

        cursor = index + 1;
    }

    // Append the trailing part after the last placeholder
    sb.addStringSlice(format, cursor, format.len);
}

clear :: method (sb: *StringBuilder) {
    memset(sb.buffer, 0, sb.capacity);
}

toString :: method (sb: *StringBuilder) -> string {
    str: string;
    str.data = sb.buffer;
    str.len  = sb.cursor;
    return str;
}

free :: method (sb: *StringBuilder) {
    free(sb.buffer);
}