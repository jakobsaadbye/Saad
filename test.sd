import "fmt";

Fruit :: enum {
    mango,
    kiwi,
    watermelon,
    dragonfruit,
    pear,
    apple,
}

Vector2 :: struct {
    x, y: float;
}

add :: method (v1, v2: Vector2) -> Vector2 {
    return {
        x = v1.x + v2.x,
        y = v1.y + v2.y,
    };
}

main :: () {
    a := Vector2{1, 3};
    b := Vector2{4, 6};
    c := a.add(b);

    print("%", c);
    // x: any = cast(u8) 5;
