import "fmt";

Button :: struct {
    onClick: (e: int) -> void;
}

main :: () {
    myButton := Button{
        onClick = (v: int) {
            Print("Click! %", v);
        }
    };

    doSomething :: (a: int) -> void {
        Print("%", a);
    }

    doSomething(10);
    myButton.onClick(5);
}