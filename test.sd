// import "fmt";

many_small_parameters :: (a, b, c, d, e, f, g, h, i, j, k, l, m: int) -> int, int, int, int, int, int, int, int, int, int, int, int, int {
    // print("% % % % % % % % % % % % %", a, b, c, d, e, f, g, h, i, j, k, l, m);
    return a, b, c, d, e, f, g, h, i, j, k, l, m;
}

foo4 :: (a, b, c, d: int) -> (int, int, int, int) {
    return a, b, c, d;
}

foo2 :: (a, b: int) -> (int, int) {
    return a, b;
}

main :: () {
    a, b, c, d := foo4(1, 2, 3, 4);
    print("% % % %", a, b, c, d);
};